<!-- app/views/posts/index.html.erb -->
<h1>Posts</h1>
<% @posts.each do |post| %>
  <% cache post do %>
    <div style="border:1px solid #ccc; padding:10px; margin-bottom:10px;">
      <h2><%= post.title %></h2>
      <p>by <%= post.user.name %> in <%= post.category.name %></p>
      <p><%= post.comments.size %> comments</p>
    </div>
  <% end %>
<% end %>
